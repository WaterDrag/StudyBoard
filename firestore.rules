rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function isMember(roomId) {
      return isAuth() &&
        request.auth.uid in
          get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
    }

    function roomRole(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.roles[request.auth.uid];
    }

    function isRoomOwner(roomId) { return roomRole(roomId) == 'owner'; }
    function canEditRoom(roomId) {
      return roomRole(roomId) == 'owner' || roomRole(roomId) == 'editor';
    }

    function deckData(deckId) { return get(/databases/$(database)/documents/decks/$(deckId)).data; }
    function isDeckOwner(deckId) { return deckData(deckId).ownerUid == request.auth.uid; }
    // A room editor/owner may manage cards in a room-scoped deck even if
    // they didn't create the deck itself (deck.ownerUid is just whoever
    // happened to create it, e.g. via the AI flashcards feature).
    function canEditDeckRoom(deckId) {
      return deckData(deckId).roomId != null && canEditRoom(deckData(deckId).roomId);
    }

    // A non-owner may write the room doc ONLY as a first-time self-join:
    // they weren't a member before, they add ONLY themselves to memberIds,
    // they touch ONLY their own key in the roles map, and they don't change
    // the owner. Crucially, an EXISTING member fails the first check
    // (`!(uid in resource memberIds)`), so a viewer can never flip their own
    // role to editor/owner from the console — only the owner can change
    // roles. The invite-link role (viewer/editor) still works because that's
    // decided at the moment of joining, before you're a member.
    function isRoomSelfJoin(roomId) {
      return !(request.auth.uid in resource.data.memberIds)
        && (request.auth.uid in request.resource.data.memberIds)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.memberIds.removeAll(resource.data.memberIds) == [request.auth.uid]
        && request.resource.data.roles.diff(resource.data.roles).affectedKeys().hasOnly([request.auth.uid]);
    }

    // ── Místnosti ──────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.auth.uid in request.resource.data.memberIds;
      allow update: if isAuth() && (
        isRoomOwner(roomId) ||
        isRoomSelfJoin(roomId)
      );
      allow delete: if isAuth() && isRoomOwner(roomId);

      match /connections/{connId} {
        allow read:   if isMember(roomId);
        // Owner may create with any authorId (needed to restore a backup and
        // keep the original author); editors only under their own name.
        allow create: if isAuth() && (isRoomOwner(roomId) ||
                         (canEditRoom(roomId) && request.resource.data.authorId == request.auth.uid));
        allow update: if isAuth() && (isRoomOwner(roomId) ||
                         resource.data.authorId == request.auth.uid);
        allow delete: if isAuth() && (isRoomOwner(roomId) ||
                         resource.data.authorId == request.auth.uid);
      }

      match /notes/{noteId} {
        allow read:   if isMember(roomId);
        allow create: if isAuth() && (isRoomOwner(roomId) ||
                         (canEditRoom(roomId) && request.resource.data.authorId == request.auth.uid));
        allow update: if isAuth() && (
          isRoomOwner(roomId) ||
          (roomRole(roomId) == 'editor' && resource.data.authorId == request.auth.uid)
        );
        allow delete: if isAuth() && (
          isRoomOwner(roomId) ||
          (roomRole(roomId) == 'editor' && resource.data.authorId == request.auth.uid)
        );
      }

      // Windows-Explorer-style folders for organizing notes in the list
      // view. Membership lives on the folder doc (noteIds[]), not on the
      // note itself — any editor can file/move any note into any folder as
      // a purely organizational action, without needing note-edit rights
      // over content someone else authored.
      match /folders/{folderId} {
        allow read:   if isMember(roomId);
        allow create: if isAuth() && (isRoomOwner(roomId) ||
                         (canEditRoom(roomId) && request.resource.data.authorId == request.auth.uid));
        allow update: if isAuth() && canEditRoom(roomId);
        allow delete: if isAuth() && canEditRoom(roomId);
      }

      // Owner-only durable snapshots of the whole room (notes + connections
      // + folders). They live server-side in Firestore, so they survive any
      // local outage, and only the owner can read/create/delete them.
      match /backups/{backupId} {
        allow read, create, delete: if isRoomOwner(roomId);
      }
    }

    // ── Uživatelské profily ────────────────────────────────────
    match /users/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ── Žádosti o přátelství ───────────────────────────────────
    match /friendRequests/{reqId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if isAuth() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuth() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
    }

    // ── Flash Card balíčky ─────────────────────────────────────
    match /decks/{deckId} {
      // resource.data místo get() – čistší a bez zbytečných reads
      allow read: if isAuth() && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.roomId != null && isMember(resource.data.roomId))
      );
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuth() && resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuth() && resource.data.ownerUid == request.auth.uid;

      match /cards/{cardId} {
        allow read: if isAuth() && (
          isDeckOwner(deckId) ||
          (deckData(deckId).roomId != null && isMember(deckData(deckId).roomId))
        );
        // Deck owner manages every card. A room editor/owner may only create
        // cards under their own name, and may only edit/delete cards they
        // authored — never someone else's, and never the deck itself.
        allow create: if isAuth() && (
          isDeckOwner(deckId) ||
          (canEditDeckRoom(deckId) && request.resource.data.authorId == request.auth.uid)
        );
        allow update, delete: if isAuth() && (
          isDeckOwner(deckId) ||
          (canEditDeckRoom(deckId) && resource.data.authorId == request.auth.uid)
        );
      }
    }

    // ── Survival co-op lobby (jen metadata; živý stav je v RTDB) ──
    match /survival_lobbies/{lobbyId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.hostId == request.auth.uid;

      // player_states (legacy) + coin_transfers
      match /{document=**} {
        allow read, write: if isAuth();
      }
    }
  }
}
